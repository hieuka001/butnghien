GEMINI_MODEL=gemini-2.5-flash
GEMINI_PLAN_MODEL=gemini-2.5-flash
GEMINI_WRITE_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# Vercel tu bat server proxy de khong lo Gemini key trong bundle.
# Neu chay bang `vercel dev` o local va muon dung proxy, mo dong duoi:
# GEMINI_SERVER_PROXY=true

# Day chuyen 6 key Gemini, chia 3 cum. Moi cum chi xoay noi bo trong 2 key cua cum do:
# Cum 1 - viet/lap khung: GEMINI_API_KEY_1, GEMINI_API_KEY_2.
# Cum 2 - tham dinh logic/canon: GEMINI_API_KEY_3, GEMINI_API_KEY_4.
# Cum 3 - sua lai theo bao cao tham dinh: GEMINI_API_KEY_5, GEMINI_API_KEY_6.
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=
# GEMINI_API_KEY_6=
# App chi doc 6 bien danh so de tranh goi nham cum nhiem vu.

# Firebase web config. FIREBASE_API_KEY duoc phep nam trong frontend neu da bat Security Rules dung.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_ID=(default)
