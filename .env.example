GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.5-flash
GEMINI_PLAN_MODEL=gemini-2.5-flash
GEMINI_WRITE_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# Vercel tu bat server proxy de khong lo Gemini key trong bundle.
# Neu chay bang `vercel dev` o local va muon dung proxy, mo dong duoi:
# GEMINI_SERVER_PROXY=true

# Tùy chọn nếu muốn xoay nhiều key Gemini trong lúc thử nghiệm:
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=

# Firebase web config. FIREBASE_API_KEY duoc phep nam trong frontend neu da bat Security Rules dung.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_ID=(default)

# Dat trong Vercel Environment Variables de dong bo tac pham len GitHub.
# Token can quyen Contents: Read and write voi repo luu tru.
GITHUB_SYNC_TOKEN=
GITHUB_SYNC_REPO=your-github-name/your-story-archive
GITHUB_SYNC_BRANCH=main
GITHUB_SYNC_PATH=but-nghien-sync
