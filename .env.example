GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.5-flash
GEMINI_PLAN_MODEL=gemini-2.5-flash
GEMINI_WRITE_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# Vercel tu bat server proxy de khong lo Gemini key trong bundle.
# Neu chay bang `vercel dev` o local va muon dung proxy, mo dong duoi:
# GEMINI_SERVER_PROXY=true

# Day chuyen 3 key Gemini:
# GEMINI_API_KEY_1 = Key 1 viet/lap khung.
# GEMINI_API_KEY_2 = Key 2 tham dinh logic/canon.
# GEMINI_API_KEY_3 = Key 3 sua lai theo bao cao Key 2.
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# Ten ro vai tro cung duoc ho tro, uu tien hon GEMINI_API_KEY_1/2/3:
# GEMINI_WRITER_API_KEY=
# GEMINI_REVIEWER_API_KEY=
# GEMINI_REWRITER_API_KEY=

# Tùy chọn nếu muốn xoay thêm key Gemini trong lúc thử nghiệm:
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=

# Firebase web config. FIREBASE_API_KEY duoc phep nam trong frontend neu da bat Security Rules dung.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_ID=(default)
